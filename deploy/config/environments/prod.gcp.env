# Local gcloud configuration name on your laptop.
GCP_CONFIG_NAME=sv-academy-website-prod

# Local gcloud account that must be active for public-site deploy commands.
GCP_ACCOUNT=aj.ajithjose@gmail.com

# GCP project id, not the human-readable project name.
GCP_PROJECT_ID=sv-academy-website

# Extra project identity check to avoid cross-account deploy accidents.
GCP_PROJECT_NUMBER=406247603858

# Public Cloud Run service.
CLOUD_RUN_REGION=us-central1
CLOUD_RUN_SERVICE=sv-academy-website
CLOUD_RUN_SERVICE_ACCOUNT_NAME=svacademy-web-runtime

# Low-cost Cloud Run runtime envelope for the public landing page.
CLOUD_RUN_MIN_INSTANCES=0
CLOUD_RUN_MAX_INSTANCES=2
CLOUD_RUN_CPU=1
CLOUD_RUN_MEMORY=512Mi
CLOUD_RUN_CONCURRENCY=80
CLOUD_RUN_TIMEOUT=60s
CLOUD_RUN_INGRESS=all
CLOUD_RUN_EXECUTION_ENVIRONMENT=gen2
CLOUD_RUN_CPU_THROTTLING=1
CLOUD_RUN_CPU_BOOST=0

# Artifact Registry image location.
ARTIFACT_REPOSITORY=svacademy
IMAGE_NAME=svacademy-web
