# shellcheck shell=bash

if [ -n "${ZSH_VERSION:-}" ]; then
	SCRIPT_PATH="${(%):-%x}"
else
	SCRIPT_PATH="${BASH_SOURCE[0]:-$0}"
fi

DEV_DIR="$(cd "$(dirname "$SCRIPT_PATH")" >/dev/null 2>&1 && pwd)"
REPO_ROOT="$(cd "$DEV_DIR/.." >/dev/null 2>&1 && pwd)"

export SVACADEMY_REPO_ROOT="$REPO_ROOT"

DEVKIT_SOURCEME="$REPO_ROOT/dev/devkit/lib/sourceme.sh"
if [ ! -f "$DEVKIT_SOURCEME" ]; then
	echo "Missing devkit submodule. Run: git submodule update --init dev/devkit" >&2
	return 1
fi
# shellcheck source=dev/devkit/lib/sourceme.sh
source "$DEVKIT_SOURCEME" || return $?

devkit_source_dev_env "$DEV_DIR"
devkit_scaffold_dev_dirs "$REPO_ROOT"
devkit_prepend_path "$REPO_ROOT/node_modules/.bin"

echo
echo "Set repo_root as: $SVACADEMY_REPO_ROOT"
echo "Use: make dev-up"
